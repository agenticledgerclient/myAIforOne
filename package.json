{
  "name": "myaiforone",
  "version": "1.1.20",
  "type": "module",
  "description": "Routes messages from phone channels to project-specific Claude Code agents",
  "bin": {
    "myaiforone": "./bin/cli.js"
  },
  "files": [
    ".claude/commands/",
    "bin/",
    "dist/",
    "!dist/launcher/",
    "!dist/*.dmg",
    "src/",
    "server/",
    "public/",
    "agents/_template/",
    "agents/platform/",
    "!agents/*/memory/",
    "!agents/*/tasks.json",
    "!agents/*/FileStorage/",
    "!agents/platform/*/memory/",
    "!agents/platform/*/tasks.json",
    "!agents/platform/*/FileStorage/",
    "config.example.json",
    "mcp-catalog.json",
    "registry/",
    "scripts/",
    "docs/",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && tsc -p server/mcp-server/tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test-message": "tsx src/test-message.ts",
    "whatsapp-login": "tsx src/whatsapp-login.ts",
    "test": "node \"Comprehensive Test Suite/run-all-tests.js\"",
    "encrypt-keys": "tsx src/encrypt-keys.ts",
    "decrypt-keys": "tsx src/decrypt-keys.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.0",
    "typescript": "^5.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@slack/events-api": "^3.0.1",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "discord.js": "^14.25.1",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "node-cron": "^4.2.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  }
}
