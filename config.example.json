{
  "service": {
    "logLevel": "debug",
    "logFile": "./logs/service.log",
    "webUI": {
      "enabled": true,
      "port": 8080,
      "webhookSecret": "CHANGE_ME_random_string"
    }
  },

  "channels": {
    "imessage": {
      "enabled": false,
      "_comment": "macOS only. Enable if on Mac with imsg CLI installed.",
      "driver": "imessage",
      "config": {
        "cliPath": "imsg",
        "includeAttachments": false,
        "debounceMs": 2000
      }
    },
    "slack": {
      "enabled": false,
      "driver": "slack",
      "config": {
        "botToken": "xoxb-YOUR-BOT-TOKEN",
        "appToken": "xapp-YOUR-APP-TOKEN",
        "mode": "socket"
      }
    },
    "telegram": {
      "enabled": false,
      "driver": "telegram",
      "config": {
        "botToken": "YOUR_BOT_TOKEN_FROM_BOTFATHER"
      }
    },
    "discord": {
      "enabled": false,
      "driver": "discord",
      "config": {
        "botToken": "YOUR_DISCORD_BOT_TOKEN"
      }
    },
    "whatsapp": {
      "enabled": false,
      "driver": "whatsapp",
      "config": {
        "authDir": "./data/whatsapp-auth"
      }
    }
  },

  "mcps": {},

  "agents": {
    "my-agent": {
      "name": "My Agent",
      "description": "General-purpose Claude agent accessible from phone",
      "workspace": "~",
      "claudeMd": "~/Desktop/personalAgents/my-agent/CLAUDE.md",
      "memoryDir": "~/Desktop/personalAgents/my-agent/memory",
      "persistent": true,
      "advancedMemory": true,
      "mentionAliases": ["@myagent"],
      "autoCommit": false,
      "allowedTools": [
        "Read", "Edit", "Write",
        "Glob", "Grep", "Bash",
        "WebFetch", "WebSearch"
      ],
      "routes": [
        {
          "channel": "telegram",
          "match": {
            "type": "chat_id",
            "value": "YOUR_CHAT_ID"
          },
          "permissions": {
            "allowFrom": ["*"],
            "requireMention": false
          }
        }
      ]
    }
  },

  "defaultAgent": null
}
