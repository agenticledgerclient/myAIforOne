{
  "service": {
    "logLevel": "debug",
    "logFile": "./logs/service.log",
    "_comment_personalAgentsDir": "Override where agent home dirs live (default: ~/Desktop/MyAIforOne Drive/PersonalAgents)",
    "personalAgentsDir": "~/Desktop/MyAIforOne Drive/PersonalAgents",
    "_comment_personalRegistryDir": "Override where personal registry data lives (default: ~/Desktop/MyAIforOne Drive/PersonalRegistry)",
    "personalRegistryDir": "~/Desktop/MyAIforOne Drive/PersonalRegistry",
    "webUI": {
      "enabled": true,
      "port": 4888,
      "webhookSecret": "CHANGE_ME_random_string"
    },
    "claudeAccounts": {
      "main": "~/.claude"
    },
    "multiModelEnabled": false,
    "platformDefaultExecutor": "claude",
    "ollamaBaseUrl": "http://localhost:11434",
    "providerKeys": {
      "openai": "",
      "xai": "",
      "google": "",
      "groq": "",
      "together": "",
      "mistral": ""
    },
    "gymEnabled": true,
    "gymOnlyMode": false,
    "aibriefingEnabled": false,
    "sharedAgentsEnabled": false,
    "_comment_sharedAgentsDir": "Override SharedAgents folder path (default: ~/Desktop/MyAIforOne Drive/SharedAgents)",
    "_comment_auth": "Enable auth for shared gateway deployments. Off by default — personal gateways stay open.",
    "auth": {
      "enabled": false,
      "tokens": [],
      "webPassword": null
    }
  },

  "channels": {
    "imessage": {
      "enabled": false,
      "_comment": "macOS only. Enable if on Mac with imsg CLI installed.",
      "driver": "imessage",
      "config": {
        "cliPath": "imsg",
        "includeAttachments": false,
        "debounceMs": 2000,
        "monitoredChatIds": []
      }
    },
    "slack": {
      "enabled": false,
      "driver": "slack",
      "config": {
        "botToken": "xoxb-YOUR-BOT-TOKEN",
        "appToken": "xapp-YOUR-APP-TOKEN",
        "mode": "socket"
      }
    },
    "telegram": {
      "enabled": false,
      "driver": "telegram",
      "config": {
        "botToken": "YOUR_BOT_TOKEN_FROM_BOTFATHER",
        "stickyRouting": "prefix",
        "stickyPrefix": "!",
        "stickyTimeoutMs": 300000
      }
    },
    "whatsapp": {
      "enabled": false,
      "driver": "whatsapp",
      "config": {
        "authDir": "./data/whatsapp-auth"
      }
    }
  },

  "mcps": {
    "_comment_platform_mcps": "REQUIRED: These platform MCPs must be registered on every installation. myaiforone-local is the gateway's own MCP server (agents, tasks, projects, orgs). aigym-platform connects to AI Gym for training programs and learner progress. Assign them to specific agents via each agent's mcps array — they are NOT auto-assigned to all agents.",

    "myaiforone-local": {
      "type": "stdio",
      "command": "node",
      "args": ["./server/mcp-server/dist/index.js"],
      "env": {
        "MYAGENT_API_URL": "http://localhost:4888"
      }
    },
    "aigym-platform": {
      "type": "http",
      "url": "https://app.aigym.studio/mcp",
      "headers": { "Authorization": "Bearer ${AIGYM_API_KEY}" }
    },

    "aiforone_computeruse": {
      "type": "stdio",
      "command": "node",
      "args": ["./mcps/aiforone_computeruse/server.js"]
    },

    "_comment_optional_mcps": "Optional MCPs below — add API keys for the services you use. Agents reference these by name in their mcps array.",

    "finney": {
      "type": "http",
      "url": "https://finneymcp.agenticledger.ai/mcp",
      "headers": { "Authorization": "Bearer ${FINNEY_API_KEY}" }
    },
