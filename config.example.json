{
  "service": {
    "logLevel": "debug",
    "logFile": "./logs/service.log",
    "_comment_personalAgentsDir": "Override where agent home dirs live (default: ~/Desktop/MyAIforOne Drive/PersonalAgents)",
    "personalAgentsDir": "~/Desktop/MyAIforOne Drive/PersonalAgents",
    "_comment_personalRegistryDir": "Override where personal registry data lives (default: ~/Desktop/MyAIforOne Drive/PersonalRegistry)",
    "personalRegistryDir": "~/Desktop/MyAIforOne Drive/PersonalRegistry",
    "webUI": {
      "enabled": true,
      "port": 4888,
      "webhookSecret": "CHANGE_ME_random_string"
    },
    "claudeAccounts": {
      "main": "~/.claude"
    }
  },

  "channels": {
    "imessage": {
      "enabled": false,
      "_comment": "macOS only. Enable if on Mac with imsg CLI installed.",
      "driver": "imessage",
      "config": {
        "cliPath": "imsg",
        "includeAttachments": false,
        "debounceMs": 2000,
        "monitoredChatIds": []
      }
    },
    "slack": {
      "enabled": false,
      "driver": "slack",
      "config": {
        "botToken": "xoxb-YOUR-BOT-TOKEN",
        "appToken": "xapp-YOUR-APP-TOKEN",
        "mode": "socket"
      }
    },
    "telegram": {
      "enabled": false,
      "driver": "telegram",
      "config": {
        "botToken": "YOUR_BOT_TOKEN_FROM_BOTFATHER",
        "stickyRouting": "prefix",
        "stickyPrefix": "!",
        "stickyTimeoutMs": 300000
      }
    },
    "whatsapp": {
      "enabled": false,
      "driver": "whatsapp",
      "config": {
        "authDir": "./data/whatsapp-auth"
      }
    }
  },

  "mcps": {
    "finney": {
