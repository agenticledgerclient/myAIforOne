          "attachments": [],
          "isVisible": true,
          "verification": "self-report"
        },
        {
          "id": "step-0-2",
          "title": "Master the One Prompt Framework",
          "order": 2,
          "type": "self-report",
          "content": "Stop writing long prompts. Use this instead:\n\n> \"I want to [TASK] for [SUCCESS CRITERIA]. Use AskUserQuestion before you start.\"",
