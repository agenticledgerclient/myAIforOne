      "title": "Claude Chat Basics (Saturday Morning)",
      "description": "Get Claude set up properly and learn the one prompt framework.",
      "order": 0,
      "agentInstructions": null,
      "isVisible": true,
      "steps": [
        {
          "id": "step-0-0",
          "title": "Install and Configure Claude",
          "order": 0,
          "type": "self-report",
          "content": "Go to claude.com/download and install the desktop app. Pay for the Pro plan ($20/month). Once inside, select **Opus 4.6 + Extended Thinking** as your model.",
